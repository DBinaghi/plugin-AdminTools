"Reset cache and update all translations after one or more language files have been "
"changed manually"
msgstr ""
"Ripristina la cache e aggiorna tutte le traduzioni dopo che uno o più file di "
"lingua sono stati modificati manualmente"

#: views/admin/index/index.php:41
msgid "including files that are part of the <b>active theme</b>."
msgstr "inclusi i file che sono parte del <b>tema attivo</b>."

#: views/admin/index/index.php:42
